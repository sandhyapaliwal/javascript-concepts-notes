Real-World Example: User Management API
Copy
class UserAPI {
  constructor(baseURL = "https://jsonplaceholder.typicode.com") {
    this.baseURL = baseURL;
  }

  // Get all users
  async getAllUsers() {
    try {
      const response = await fetch(`${this.baseURL}/users`);
      if (!response.ok) throw new Error("Failed to fetch users");
      return await response.json();
    } catch (error) {
      console.error("Error fetching users:", error);
    }
  }

  // Get single user
  async getUser(userId) {
    try {
      const response = await fetch(`${this.baseURL}/users/${userId}`);
      if (!response.ok) throw new Error("User not found");
      return await response.json();
    } catch (error) {
      console.error("Error fetching user:", error);
    }
  }

  // Create new user
  async createUser(userData) {
    try {
      const response = await fetch(`${this.baseURL}/users`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(userData)
      });
      if (!response.ok) throw new Error("Failed to create user");
      return await response.json();
    } catch (error) {
      console.error("Error creating user:", error);
    }
  }

  // Update user
  async updateUser(userId, userData) {
    try {
      const response = await fetch(`${this.baseURL}/users/${userId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(userData)
      });
      if (!response.ok) throw new Error("Failed to update user");
      return await response.json();
    } catch (error) {
      console.error("Error updating user:", error);
    }
  }

  // Delete user
  async deleteUser(userId) {
    try {
      const response = await fetch(`${this.baseURL}/users/${userId}`, {
        method: "DELETE"
      });
      if (!response.ok) throw new Error("Failed to delete user");
      return { success: true };
    } catch (error) {
      console.error("Error deleting user:", error);
    }
  }
}

// Usage
const userAPI = new UserAPI();

// Get all users
const users = await userAPI.getAllUsers();
console.log(users);

// Create new user
const newUser = await userAPI.createUser({
  name: "John Doe",
  email: "john@example.com"
});
console.log(newUser);

// Update user
const updated = await userAPI.updateUser(1, {
  name: "Jane Doe",
  email: "jane@example.com"
});

// Delete user
await userAPI.deleteUser(1);
Best Practices for API Calling
1. Use Environment Variables for API URLs
Copy
const API_URL = process.env.REACT_APP_API_URL || "http://localhost:3000";
2. Create Reusable API Service
Copy
// apiService.js
export const apiCall = async (endpoint, options = {}) => {
  try {
    const response = await fetch(`${process.env.REACT_APP_API_URL}${endpoint}`, {
      headers: {
        "Content-Type": "application/json",
        ...options.headers
      },
      ...options
    });
    
    if (!response.ok) {
      throw new Error(`API Error: ${response.status}`);
    }
    
    return await response.json();
  } catch (error) {
    console.error("API call failed:", error);
    throw error;
  }
};
3. Always Handle Loading and Error States
Copy
async function fetchUserData(userId) {
  let isLoading = true;
  let data = null;
  let error = null;

  try {
    data = await fetch(`/api/users/${userId}`).then(r => r.json());
  } catch (err) {
    error = err;
  } finally {
    isLoading = false;
  }

  return { isLoading, data, error };
}
4. Set Request Timeouts
Copy
const fetchWithTimeout = (url, timeout = 5000) => {
  return Promise.race([
    fetch(url),
    new Promise((_, reject) =>
      setTimeout(() => reject(new Error("Request timeout")), timeout)
    )
  ]);
};
5. Use Proper Headers
Copy
const headers = {
  "Content-Type": "application/json",
  "Authorization": `Bearer ${token}`,
  "X-API-Key": process.env.API_KEY
};
6. Validate API Responses
Copy
async function getUser(userId) {
  try {
    const data = await fetch(`/api/users/${userId}`).then(r => r.json());
    
    // Validate response structure
    if (!data.id || !data.name) {
      throw new Error("Invalid user data");
    }
    
    return data;
  } catch (error) {
    console.error("Error:", error);
  }
}
Fetch API vs Axios Comparison
Feature	Fetch API	Axios
Built-in	Yes	No (requires installation)
Syntax	Verbose	Concise
Error Handling	Manual status checks	Automatic
Timeout	No native support	Built-in
Request/Response Interceptors	No	Yes
JSON Auto-convert	.json() method	Automatic
Browser Support	All modern browsers	All modern browsers
Conclusion
API calling is essential in modern web development. Both Fetch API and Axios are excellent choices:

Use Fetch API for simple projects and when you want zero dependencies
Use Axios for complex applications that need interceptors and cleaner syntax
Master async/await syntax for cleaner, more readable code, and always remember to handle errors gracefully.
